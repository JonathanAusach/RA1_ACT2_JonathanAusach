<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/buttonBackAct10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="17dp"
        android:text="Back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView11"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="45dp"
        android:layout_marginTop="37dp"
        android:scaleX="2"
        android:scaleY="2"
        android:text="ACT 10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonBackAct10" />

    <Button
        android:id="@+id/buttonFristActivity"
        android:layout_width="227dp"
        android:layout_height="111dp"
        android:layout_marginStart="92dp"
        android:layout_marginTop="147dp"
        android:text="Frist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonBackAct10" />

    <Button
        android:id="@+id/buttonSecondActivity"
        android:layout_width="227dp"
        android:layout_height="111dp"
        android:layout_marginStart="92dp"
        android:layout_marginTop="82dp"
        android:text="Second"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonFristActivity" />

</androidx.constraintlayout.widget.ConstraintLayout>